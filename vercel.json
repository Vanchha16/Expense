{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "api/migrate.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/migrate-run", "dest": "/api/migrate.php" },
    { "src": "/(.*)",        "dest": "/api/index.php"   }
  ]
}
