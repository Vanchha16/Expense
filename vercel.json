{
  "version": 2,
  "framework": null,
  "installCommand": "composer install --no-dev --optimize-autoloader",
  "buildCommand": "php artisan config:cache && php artisan route:cache && php artisan view:cache && php artisan migrate --force",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
